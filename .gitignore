# Build & Artifacts (Essential Flutter/Dart Exclusions)
/build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
pubspec.lock

# Dependencies & Cache
.pub-cache/
.pub/
**/doc/api/
/coverage/

# IDE & OS Files
# IntelliJ/Android Studio
*.iml
*.ipr
*.iws
.idea/

# VS Code (Uncomment to ignore local settings, otherwise include them)
# .vscode/

# macOS
.DS_Store

# Miscellaneous and Common Language Artifacts
*.class
*.log
*.pyc
*.swp
.history
.svn/
.atom/
.swiftpm/
migrate_working_dir/

# Platform-Specific Generated Files
# These are generated by the Flutter tool and should not be tracked.
android/app/build/
android/app/src/main/kotlin/com/example/myapp/MainActivity.kt
android/app/src/main/res/drawable-v21/launch_background.xml
android/app/src/main/res/drawable/launch_background.xml
android/app/src/main/res/mipmap-*/ic_launcher.png

# Generated plugin files (from platform folders)
linux/flutter/generated_plugin_registrant.cc
linux/flutter/generated_plugins.cmake
macos/Flutter/GeneratedPluginRegistrant.swift
windows/flutter/generated_plugin_registrant.cc
windows/flutter/generated_plugins.cmake

# Android build output directories
/android/app/debug
/android/app/profile
/android/app/release

# Symbolication and Obfuscation (Keeping these for production builds)
app.*.symbols
app.*.map.json